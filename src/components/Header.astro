---
import { Menu, Moon, Search, Sun, X } from "@lucide/astro";
---

<header class="w-full">
  <a
    id="skip-to-content"
    href="#main-content"
    class="focus-outline absolute -top-full left-4 z-50 bg-background px-3 py-2 text-accent transition-all focus:top-4"
  >
    Skip to content
  </a>
  <div class="mx-auto max-w-4xl px-4">
    <div class="relative flex flex-col items-center justify-between py-4 sm:flex-row sm:py-6">
      <a href="/" class="focus-outline absolute left-0 top-4 py-1 text-2xl font-semibold leading-7 sm:static">
        Shad Khan
      </a>
      <nav class="flex w-full flex-col items-center sm:ml-4 sm:flex-row sm:justify-end" aria-label="Primary">
        <button
          data-menu-button
          class="focus-outline self-end p-2 sm:hidden"
          type="button"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="menu-items"
        >
          <Menu data-menu-open-icon class="size-6" aria-hidden="true" />
          <X data-menu-close-icon class="hidden size-6" aria-hidden="true" />
        </button>
        <ul
          id="menu-items"
          data-menu-items
          class="mt-4 hidden w-44 grid-cols-2 place-content-center gap-2 text-sm font-medium sm:mt-0 sm:flex sm:w-auto sm:items-center sm:gap-5"
        >
          <li class="col-span-2"><a class="focus-outline block px-4 py-3 text-center hover:text-accent sm:px-0 sm:py-1" href="/posts/">Posts</a></li>
          <li class="col-span-2"><a class="focus-outline block px-4 py-3 text-center hover:text-accent sm:px-0 sm:py-1" href="/about/">About</a></li>
          <li class="flex items-center justify-center">
            <a class="focus-outline inline-flex size-11 items-center justify-center hover:text-accent sm:size-8" href="/search/" aria-label="Search" title="Search">
              <Search class="size-5" aria-hidden="true" />
            </a>
          </li>
          <li class="flex items-center justify-center">
            <button
              data-theme-toggle
              class="focus-outline inline-flex size-11 items-center justify-center hover:text-accent sm:size-8"
              type="button"
              aria-label="Toggle theme"
              title="Toggle theme"
            >
              <Moon class="size-5 dark:hidden" aria-hidden="true" />
              <Sun class="hidden size-5 dark:block" aria-hidden="true" />
            </button>
          </li>
        </ul>
      </nav>
    </div>
    <hr class="border-border" aria-hidden="true" />
  </div>
</header>

<script>
  function setupMenu() {
    const button = document.querySelector("[data-menu-button]");
    const menu = document.querySelector("[data-menu-items]");
    const openIcon = document.querySelector("[data-menu-open-icon]");
    const closeIcon = document.querySelector("[data-menu-close-icon]");

    if (!button || !menu || !openIcon || !closeIcon || button.dataset.bound === "true") return;

    button.dataset.bound = "true";
    button.addEventListener("click", () => {
      const isOpen = button.getAttribute("aria-expanded") === "true";
      button.setAttribute("aria-expanded", String(!isOpen));
      button.setAttribute("aria-label", isOpen ? "Open menu" : "Close menu");
      menu.classList.toggle("hidden", isOpen);
      openIcon.classList.toggle("hidden", !isOpen);
      closeIcon.classList.toggle("hidden", isOpen);
    });
  }

  setupMenu();
  document.addEventListener("astro:page-load", setupMenu);
</script>
