---
import { CalendarDays } from "@lucide/astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/posts";

type Post = CollectionEntry<"posts">;

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => data.draft !== true);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props as { post: Post };
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="py-10">
    <a href="/posts/" class="focus-outline inline-block text-sm font-medium text-accent hover:underline">Posts</a>
    <h1 class="mt-4 max-w-2xl text-3xl font-bold sm:text-4xl">{post.data.title}</h1>
    <div class="mt-4 flex flex-wrap items-center gap-3 text-sm italic text-muted">
      <span class="inline-flex items-center gap-2">
        <CalendarDays class="size-4" aria-hidden="true" />
        <span class="sr-only">Published:</span>
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
      </span>
      <span aria-hidden="true">-</span>
      <span>{post.data.minutes} min read</span>
    </div>
    <div class="prose-blog mt-10">
      <Content />
    </div>
  </article>
</BaseLayout>
