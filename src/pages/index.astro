---
import { ArrowRight, Rss } from "@lucide/astro";
import PostList from "../components/PostList.astro";
import SocialLinks from "../components/SocialLinks.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSortedPosts } from "../lib/posts";

const posts = await getSortedPosts();
---

<BaseLayout title="Shad Khan" description="AI, programming, and practical field notes from Shad Khan.">
  <section id="hero" class="pt-6 pb-4">
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:items-start">
      <a href="/about/" class="focus-outline group block shrink-0" aria-label="About Shad Khan">
        <img
          src="/avatar.svg"
          alt="Shad Khan avatar"
          class="size-36 rounded-full object-cover transition duration-300 group-hover:scale-105 group-hover:shadow-xl sm:size-40"
          width="160"
          height="160"
        />
      </a>
      <div class="flex-1 text-center sm:text-left">
        <div class="flex items-center justify-center gap-2 sm:justify-start">
          <h1 class="my-2 inline-block text-2xl font-bold sm:my-4 sm:text-3xl">Hi, I'm Shad Khan.</h1>
          <a href="/rss.xml" class="focus-outline inline-flex text-accent" aria-label="RSS feed" title="RSS feed">
            <Rss class="size-5 stroke-[3]" aria-hidden="true" />
          </a>
        </div>
        <p class="text-muted">
          AI, programming, and practical notes from everyday software work.<br class="hidden sm:block" />
          Small experiments, useful defaults, and hard-won workflows.
        </p>
        <div class="mt-4">
          <SocialLinks />
        </div>
      </div>
    </div>
  </section>

  <hr class="border-border" aria-hidden="true" />

  <section id="recent-posts" class="pt-12 pb-6" aria-labelledby="recent-posts-heading">
    <h2 id="recent-posts-heading" class="sr-only">Recent posts</h2>
    <PostList posts={posts.slice(0, 6)} />
  </section>

  <div class="my-8 text-center">
    <a href="/posts/" class="focus-outline group inline-flex items-center gap-1 hover:text-accent">
      All posts
      <ArrowRight class="size-5 transition group-hover:translate-x-1" aria-hidden="true" />
    </a>
  </div>
</BaseLayout>
